{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cad-intelligence.local/scheme-v1.schema.json",
  "title": "CadIntelligence Scheme v1",
  "description": "工程绘图 scheme JSON — 支持 PFD / P&ID / 3D 布置（见 schemas/VDI_FIELD_MAPPING.md）",
  "type": "object",
  "required": ["input_type", "project_info", "geometry", "output_config"],
  "properties": {
    "input_type": {
      "type": "string",
      "enum": ["scheme"]
    },
    "project_info": {
      "type": "object",
      "required": ["drawing_number"],
      "properties": {
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "drawing_number": { "type": "string" },
        "drawing_title": { "type": "string" },
        "revision": { "type": "string", "default": "A" },
        "description": { "type": "string" }
      }
    },
    "streams": {
      "type": "array",
      "description": "PFD 物流表（阶段1 MUST）",
      "items": { "$ref": "#/$defs/stream" }
    },
    "geometry": {
      "type": "object",
      "required": ["objects", "connections"],
      "properties": {
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/equipment" }
        },
        "connections": {
          "type": "array",
          "items": { "$ref": "#/$defs/connection" }
        },
        "instruments": {
          "type": "array",
          "description": "P&ID 仪表（阶段2）",
          "items": { "$ref": "#/$defs/instrument" }
        }
      }
    },
    "tables": {
      "type": "object",
      "properties": {
        "pipe_list": {
          "type": "array",
          "items": { "$ref": "#/$defs/pipe_list_row" }
        },
        "stream_list": {
          "type": "array",
          "items": { "$ref": "#/$defs/stream_list_row" }
        },
        "equipment_list": {
          "type": "array",
          "items": { "$ref": "#/$defs/equipment_list_row" }
        },
        "boundary_list": {
          "type": "array",
          "description": "界区接点表（阶段2 CP-2）"
        },
        "cause_effect": {
          "type": "array",
          "description": "因果图（阶段2 CP-2）"
        }
      }
    },
    "annotations": { "type": "object" },
    "output_config": {
      "type": "object",
      "required": ["drawing_type"],
      "properties": {
        "drawing_type": {
          "type": "string",
          "enum": ["pfd", "pid", "2d", "3d", "model", "layout", "isometric"]
        },
        "format": { "type": "string" },
        "scale": { "type": "string" },
        "dimension_standard": { "type": "string", "default": "GB" },
        "paper_size": { "type": "string", "default": "A3" },
        "orientation": { "type": "string", "enum": ["landscape", "portrait"] }
      }
    },
    "vdi_source": {
      "type": "object",
      "description": "VDI 数据来源追溯（可选）",
      "properties": {
        "material_balance_ref": { "type": "string" },
        "equipment_datasheet_ref": { "type": "string" },
        "control_philosophy_ref": { "type": "string" },
        "cp_stage": { "type": "string", "enum": ["CP-0", "CP-1", "CP-2", "CP-3"] }
      }
    }
  },
  "$defs": {
    "equipment": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "设备位号 P-1001" },
        "type": { "type": "string" },
        "symbol_id": { "type": "string" },
        "ai_type": { "type": "string" },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "rotation": { "type": "number" },
        "scale": { "type": "number" },
        "parameters": { "type": "object" }
      }
    },
    "connection": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "default": "pipe" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "label": { "type": "string", "description": "管段号" },
        "stream_no": { "type": "string", "description": "物流号" },
        "parameters": {
          "type": "object",
          "properties": {
            "diameter": { "type": ["string", "number"] },
            "DN": { "type": ["string", "number"] },
            "medium": { "type": "string" },
            "material": { "type": "string" },
            "insulation": { "type": "string" },
            "design_T_C": { "type": "number" },
            "design_P_MPa": { "type": "number" },
            "oper_T_C": { "type": "number" },
            "oper_P_MPa": { "type": "number" }
          }
        }
      }
    },
    "stream": {
      "type": "object",
      "required": ["stream_no"],
      "properties": {
        "stream_no": { "type": "string" },
        "connection_id": { "type": "string" },
        "from_tag": { "type": "string" },
        "to_tag": { "type": "string" },
        "flow": { "type": "string" },
        "phase": { "type": "string" },
        "T_C": { "type": "number" },
        "P_MPa": { "type": "number" },
        "medium": { "type": "string" },
        "composition": { "type": "string" }
      }
    },
    "pipe_list_row": {
      "type": "object",
      "properties": {
        "line_no": { "type": "string" },
        "stream_no": { "type": "string" },
        "from_tag": { "type": "string" },
        "to_tag": { "type": "string" },
        "DN": { "type": ["string", "number"] },
        "medium": { "type": "string" },
        "flow": { "type": "string" },
        "phase": { "type": "string" },
        "material": { "type": "string" },
        "insulation": { "type": "string" },
        "design_T_C": { "type": "number" },
        "design_P_MPa": { "type": "number" },
        "oper_T_C": { "type": "number" },
        "oper_P_MPa": { "type": "number" }
      }
    },
    "stream_list_row": {
      "type": "object",
      "properties": {
        "stream_no": { "type": "string" },
        "from_tag": { "type": "string" },
        "to_tag": { "type": "string" },
        "flow": { "type": "string" },
        "T_C": { "type": "number" },
        "P_MPa": { "type": "number" },
        "phase": { "type": "string" }
      }
    },
    "equipment_list_row": {
      "type": "object",
      "properties": {
        "tag": { "type": "string" },
        "type": { "type": "string" },
        "oper_T_C": { "type": "number" },
        "oper_P_MPa": { "type": "number" }
      }
    },
    "instrument": {
      "type": "object",
      "description": "P&ID 仪表（阶段2）",
      "properties": {
        "tag": { "type": "string" },
        "type": { "type": "string" },
        "loop": { "type": "string" },
        "location": { "type": "string" },
        "on_line": { "type": "string" },
        "range": { "type": "string" },
        "signal": { "type": "string" }
      }
    }
  }
}

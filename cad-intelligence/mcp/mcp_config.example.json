{
  "mcpServers": {
    "cad-intelligence": {
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "python3",
      "args": [
        "/path/to/cad-intelligence/mcp/cad_mcp_client.py"
      ],
      "env": {
        "OLLAMA_BASE": "http://127.0.0.1:11434",
        "OLLAMA_MODEL": "qwen3.5:9b-mlx"
      }
    },
    "freecad-mcp": {
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "command": "python3",
      "args": [
        "/path/to/FreeCAD-MCP/src/freecad_mcp_client.py"
      ]
    }
  }
}

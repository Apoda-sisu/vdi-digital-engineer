  "clauses": [
    {
      "clause_id": "SHT30112017-5-1",
      "source_type": "standard",
      "source_id": "SH/T 3011-2017",
      "version": "",
      "discipline": "process",
      "clause": "5.1",
      "content": "工艺装置布置应满足防火、安全、操作及维修要求，并便于物料输送和能量利用。",
      "keywords": [
        "装置布置",
        "防火间距"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D04"
      ],
      "category": "补充"
    },
    {
      "clause_id": "SHT30112017-5-2",
      "source_type": "standard",
      "source_id": "SH/T 3011-2017",
      "version": "",
      "discipline": "process",
      "clause": "5.2",
      "content": "设备布置应留有满足检修、吊装及更换催化剂/内件所需的空间和通道。",
      "keywords": [
        "设备布置",
        "检修"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D04"
      ],
      "category": "补充"
    },
    {
      "clause_id": "SHT30072014-4-1",
      "source_type": "standard",
      "source_id": "SH/T 3007-2014",
      "version": "",
      "discipline": "process",
      "clause": "4.1",
      "content": "可燃液体储罐区与工艺装置防火间距应符合 GB 50160 及本规范规定。",
      "keywords": [
        "储罐",
        "防火间距"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D02"
      ],

    {
      "clause_id": "VDI-PR-DDS-RET",
      "source_type": "rule",
      "source_id": "VDI-PR-DDS-001",
      "version": "2026",
      "discipline": "process",
      "clause": "1.0",
      "content": "工艺设备数据表必填字段：设备位号、设备名称、型式、数量、设计温度、设计压力、操作温度、操作压力、介质名称及组成、材质要求、主要尺寸、工艺性能参数（如换热面积、塔板数、流量/扬程）及驱动功率（动设备）。",
      "keywords": ["工艺设备数据表", "工艺设备数据表必填字段", "设备数据表", "设计条件"],

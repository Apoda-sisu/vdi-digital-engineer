      "source_id": "VDI-PR-CTL-001",
      "version": "2026",
      "discipline": "process",
      "clause": "1.0",
      "content": "控制哲学应包含哪些内容：各控制回路控制目的、测量点位置、控制策略（单回路/串级/比值/分程）、正常及异常报警限值、联锁触发条件概要、手动/自动切换原则及 DCS/PLC 组态要求接口。",
      "keywords": ["控制哲学", "控制哲学应包含哪些内容", "控制策略", "报警限值", "联锁"],
      "mandatory": true,

      "source_id": "VDI-PR-UTIL-001",
      "version": "2026",
      "discipline": "process",
      "clause": "1.0",
      "content": "公用工程消耗汇总表内容应包括：各压力等级蒸汽产/用/购/排量，循环水/冷冻水补充与排放量，仪表风/氮气/燃料气用量，以及对应 UID/UFD 图编号引用。",
      "keywords": ["公用工程消耗汇总表", "公用工程消耗汇总表内容", "蒸汽平衡", "UID"],

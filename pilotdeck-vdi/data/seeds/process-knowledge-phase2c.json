      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "5.1",
      "content": "物料平衡表编制要求：应包括全装置总平衡和各单元详细平衡；每条流股标注编号、名称、质量/摩尔流量、组成、温度、压力、相态；总进等于总出加损失，闭合误差不超过1%。",
      "keywords": ["物料平衡表", "物料平衡表编制要求", "流股", "闭合误差", "HMB"],
      "mandatory": true,
      "skill_tags": ["PR-D03"],
      "category": "检索优化"
    },
    {

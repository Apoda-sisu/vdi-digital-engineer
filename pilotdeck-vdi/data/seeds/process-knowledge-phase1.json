      "mandatory": true,
      "skill_tags": [
        "PX1206",
        "PX3342"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "SHT3121-2022-7.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.0",
      "content": "工艺设计应对主要工艺设备进行选型设计，包括反应器、塔器、换热器、加热炉、泵和压缩机等，设备选型应满足工艺要求和材料耐腐蚀要求。",

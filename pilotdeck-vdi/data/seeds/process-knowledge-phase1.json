      "mandatory": true,
      "skill_tags": [
        "PX8248"
      ],
      "category": "自动控制"
    },
    {
      "clause_id": "SHT3121-2022-10.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "10.0",
      "content": "工艺设计应满足环境保护和职业卫生要求，提出三废治理方案及排放指标，但详细环保设计由环保/HSE 专业完成。",

    {
      "clause_id": "SHT3121-2022-1.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "1.0",
      "content": "本规范规定了以石油和石油产品为原料的石油化工装置的工艺设计原则及技术要求，适用于新建石油化工装置的工艺设计。",
      "keywords": [
        "工艺设计规范",
        "石油化工",
        "适用范围"
      ],
      "mandatory": true,
      "skill_tags": [

      ],
      "category": "总则"
    },
    {
      "clause_id": "SHT3121-2022-3.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "3.0",
      "content": "工艺设计应遵循技术先进、安全可靠、经济合理、节约能源、保护环境的原则，并满足国家和行业现行标准的要求。",
      "keywords": [
        "设计原则",
        "安全",
        "节能",
        "环保"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980"
      ],
      "category": "设计原则"
    },
    {
      "clause_id": "SHT3121-2022-4.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "4.0",
      "content": "工艺流程设计应合理选择流程方案，优化物料和能量利用，减少三废排放；流程图应清晰表示主要设备、物流和控制方案。",
      "keywords": [
        "工艺流程",
        "流程优化",
        "能量利用",
        "三废"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX2366"
      ],
      "category": "工艺流程"
    },
    {
      "clause_id": "SHT3121-2022-5.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "5.0",
      "content": "工艺设计应进行物料平衡和能量平衡计算，作为设备选型和工艺参数确定的依据；平衡表应标注各流股的流量、组成、温度、压力。",
      "keywords": [
        "物料平衡",
        "能量平衡",
        "流股表",
        "设备选型"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX3342"
      ],
      "category": "物料能量平衡"
    },
    {
      "clause_id": "SHT3121-2022-6.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "6.0",
      "content": "工艺设计应提出装置能耗指标及节能措施，典型装置的能耗值可参考规范附录；应通过换热网络优化等手段降低单位产品能耗。",
      "keywords": [
        "能耗指标",
        "节能措施",
        "换热网络"
      ],
      "mandatory": false,
      "skill_tags": [
        "PX3342",
        "PR-S04"
      ],
      "category": "能耗与节能"
    },
    {
      "clause_id": "SHT3121-2022-8.0",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "8.0",
      "content": "工艺设计应进行安全泄压与危险介质排放设计，包括安全阀、爆破片、紧急泄压和火炬系统的设置原则，确保超压保护可靠。",
      "keywords": [
        "安全泄压",
        "安全阀",
        "爆破片",
        "火炬",
        "超压保护"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504",
        "PR-X01"
      ],
      "category": "安全泄压"
    },
    {

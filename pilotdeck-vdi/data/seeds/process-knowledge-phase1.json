    },
    {
      "clause_id": "VDI-PR-SIM-001",
      "source_type": "rule",
      "source_id": "VDI-PR-SIM-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "流程模拟应覆盖正常工况及关键异常工况，物性方法选择应有依据并记录；模拟结果应输出至 H&MB 表和 PFD 流股数据。",

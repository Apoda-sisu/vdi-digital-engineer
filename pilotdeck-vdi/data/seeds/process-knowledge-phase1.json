    {
      "clause_id": "VDI-PR-PFD-001",
      "source_type": "rule",
      "source_id": "VDI-PR-PFD-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "PFD（工艺流程图）应标注所有主要设备位号、物流号及关键操作参数（温度、压力、流量），并附物料平衡表；PFD 不包含详细管道等级、阀门类型和仪表控制回路细节。",
      "keywords": [
        "PFD",
        "物流号",
        "设备位号",
        "物料平衡"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2366"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-PID-001",
      "source_type": "rule",
      "source_id": "VDI-PR-PID-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "P&ID（管道及仪表流程图）是跨专业主文档，应包含全部设备、管道、阀门、仪表、控制回路、安全联锁及放空泄压设施；P&ID 是 HAZOP 分析、配管设计和仪控设计的直接依据。",
      "keywords": [
        "P&ID",
        "跨专业",
        "HAZOP",
        "控制回路",
        "安全联锁"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S01",
        "PR-X01"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-CTL-001",
      "source_type": "rule",
      "source_id": "VDI-PR-CTL-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "控制哲学（Control Philosophy）由工艺专业主导编制，应描述各控制回路的目的、测量点、控制策略、报警限值及联锁逻辑概要；仪控专业负责审签和细化 DCS/PLC 组态要求。",
      "keywords": [
        "控制哲学",
        "控制回路",
        "联锁",
        "报警"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX8248"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-HMB-001",
      "source_type": "rule",
      "source_id": "VDI-PR-HMB-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "物料平衡表应标注每个流股的编号、名称、流量（质量/摩尔）、组成、温度、压力及相态；全厂总平衡与各单元平衡应分别编制，闭合误差不应超过 1%。",
      "keywords": [
        "物料平衡",
        "流股",
        "闭合误差",
        "HMB"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX3342"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-DDS-001",
      "source_type": "rule",
      "source_id": "VDI-PR-DDS-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "工艺设备数据表应包含：设备位号、名称、型式、设计/操作温度压力、介质组成、材质要求、主要尺寸及工艺性能参数；静设备数据表由工艺提出工艺条件，设备专业补充机械设计。",
      "keywords": [
        "设备数据表",
        "设计条件",
        "操作条件",
        "工艺设备"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2365"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-ROUTE-001",
      "source_type": "rule",
      "source_id": "VDI-PR-ROUTE-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "工艺路线比选应至少比较三种可行方案，从投资、能耗、原料消耗、三废排放、安全性及操作灵活性等维度进行技术经济比较，最终方案由人类决策。",
      "keywords": [
        "工艺路线",
        "方案比选",
        "技术经济"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-UTIL-001",
      "source_type": "rule",
      "source_id": "VDI-PR-UTIL-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "公用工程平衡应分别编制蒸汽（各压力等级）、循环水、冷冻水、仪表风、氮气、燃料气等系统的产用平衡表，并汇总至 UID/UFD 图。",
      "keywords": [
        "公用工程",
        "蒸汽平衡",
        "UID",
        "UFD"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S04"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-REL-001",
      "source_type": "rule",
      "source_id": "VDI-PR-REL-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "安全阀泄放量计算应依据 API RP 520/521，考虑所有可信超压场景（火灾、Blocked outlet、冷却失效等），泄放量汇总表是火炬系统设计的输入。",
      "keywords": [
        "安全阀",
        "API 520",
        "泄放量",
        "火炬"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504",
        "PR-T07"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-HAZOP-001",
      "source_type": "rule",
      "source_id": "VDI-PR-HAZOP-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "HAZOP 分析应在 P&ID 达到 60% 深度时进行，以 P&ID 节点为分析单元，采用 IEC 61882 引导词法；工艺工程师作为工艺知识专家参与，HSE 负责主席和记录。",
      "keywords": [
        "HAZOP",
        "IEC 61882",
        "P&ID",
        "节点"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-X01"
      ],
      "category": "VDI工艺规则"
    },
    {
      "clause_id": "VDI-PR-LAB-001",
      "source_type": "rule",
      "source_id": "VDI-PR-LAB-001",
      "version": "2026",
      "discipline": "PX",
      "clause": "1.0",
      "content": "取样点汇总表应标注取样点编号、位置、取样介质、分析项目、取样频率及取样器型式；工艺包和基础设计阶段均须提交。",

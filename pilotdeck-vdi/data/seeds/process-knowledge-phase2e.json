      "mandatory": true,
      "skill_tags": [
        "PR-S05"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-9-5-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "9.5",
      "content": "分程控制及选择性控制应在控制哲学中单独说明应用场景。",
      "keywords": [
        "分程",
        "选择性控制"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S05"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-10-3-e",

{
  "seed_version": "2e",
  "discipline": "process",
  "description": "Sprint 5 Phase 2e 扩展",
  "clauses": [
    {
      "clause_id": "SHT31212022-4-5-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "4.5",
      "content": "对催化反应装置，工艺设计应明确催化剂装填量、预期寿命及再生/更换周期。",
      "keywords": [
        "催化剂",
        "寿命",
        "再生"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D02",
        "PR-D05"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-4-6-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "4.6",
      "content": "对分离序列设计，应评估热集成方案及对公用工程消耗的影响。",
      "keywords": [
        "分离序列",
        "热集成"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D02",
        "PR-D03"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-5-4-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "5.4",
      "content": "流股表应给出各流股的质量流量、摩尔分率、温度、压力及相态。",
      "keywords": [
        "流股表",
        "摩尔分率",
        "相态"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D03"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-5-5-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "5.5",
      "content": "对含腐蚀性介质，物料平衡应标注氯离子、硫化氢等关键杂质浓度。",
      "keywords": [
        "腐蚀",
        "杂质",
        "H2S"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D03",
        "PR-S01"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-7-6-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "7.6",
      "content": "储罐设计应明确储存温度、呼吸损失、氮封要求及高低液位联锁。",
      "keywords": [
        "储罐",
        "氮封",
        "液位联锁"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D05",
        "PR-S05"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-7-7-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "7.7",
      "content": "过滤器/筛网选型应满足 Startup 及正常操作固体颗粒控制要求。",
      "keywords": [
        "过滤器",
        "Startup"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-D05"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-8-5-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "8.5",
      "content": "对毒性介质 PSV 排放，应评估火炬燃烧效率及地面浓度影响。",
      "keywords": [
        "毒性",
        "火炬燃烧"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S03"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-8-6-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "8.6",
      "content": "真空系统泄压应同时考虑正向超压及反向超压（ implosion ）保护。",
      "keywords": [
        "真空",
        "超压",
        "implosion"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S03"
      ],
      "category": "SH/T3121-扩展"
    },
    {
      "clause_id": "SHT31212022-9-4-e",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "process",
      "clause": "9.4",
      "content": "串级控制方案应明确主副回路职责及防积分饱和措施。",
      "keywords": [

{
  "seed_version": 2,
  "discipline": "process",
  "description": "Sprint 3 Phase 2 — SH/T 3121、GB/T 50933、HG/T 20570、API 520 扩展",
  "clauses": [
    {
      "clause_id": "SHT3121-2022-3-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "3.1",
      "content": "工艺设计应进行技术来源可靠性论证，明确专利或专有技术使用范围及限制条件。",
      "keywords": [
        "技术来源",
        "专利",
        "专有技术"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-总则"
    },
    {
      "clause_id": "SHT3121-2022-3-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "3.2",
      "content": "工艺设计文件应满足后续基础设计和详细设计开展的需要，各阶段深度应符合 GB/T 50933 规定。",
      "keywords": [
        "设计阶段",
        "设计深度",
        "GB50933"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-总则"
    },
    {
      "clause_id": "SHT3121-2022-4-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "4.1",
      "content": "工艺流程选择应通过多方案比选确定，比选因素包括投资、能耗、原料消耗、产品质量、三废排放及操作安全性。",
      "keywords": [
        "方案比选",
        "工艺流程"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-工艺流程"
    },
    {
      "clause_id": "SHT3121-2022-4-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "4.2",
      "content": "工艺设计应明确各工段功能划分，分工段叙述物料流向及主要操作参数。",
      "keywords": [
        "工段",
        "物料流向",
        "操作参数"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-工艺流程"
    },
    {
      "clause_id": "SHT3121-2022-4-3",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "4.3",
      "content": "对连续生产装置，应明确正常、启动、停车及紧急工况下的工艺控制要求。",
      "keywords": [
        "开停车",
        "紧急工况",
        "控制要求"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-工艺流程"
    },
    {
      "clause_id": "SHT3121-2022-4-4",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "4.4",
      "content": "工艺设计应合理设置中间储罐及缓冲设施，其容积应满足上下游操作弹性要求。",
      "keywords": [
        "缓冲",
        "中间罐",
        "操作弹性"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-工艺流程"
    },
    {
      "clause_id": "SHT3121-2022-5-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "5.1",
      "content": "物料平衡计算应包括全装置总平衡和各生产单元平衡，并标注各流股编号及物性数据。",
      "keywords": [
        "物料平衡",
        "流股",
        "物性"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-物料能量平衡"
    },
    {
      "clause_id": "SHT3121-2022-5-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "5.2",
      "content": "能量平衡应包括反应热、显热、潜热及公用工程消耗，并识别能量回收机会。",
      "keywords": [
        "能量平衡",
        "反应热",
        "能量回收"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-物料能量平衡"
    },
    {
      "clause_id": "SHT3121-2022-5-3",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "5.3",
      "content": "工艺设计应给出主要原料、辅助材料及公用工程的单位产品消耗定额。",
      "keywords": [
        "消耗定额",
        "原料",
        "公用工程"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-物料能量平衡"
    },
    {
      "clause_id": "SHT3121-2022-6-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "6.1",
      "content": "装置能耗指标应作为工艺设计评价依据，并列出主要节能措施及预期效果。",
      "keywords": [
        "能耗指标",
        "节能措施"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-能耗"
    },
    {
      "clause_id": "SHT3121-2022-6-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "6.2",
      "content": "应通过换热网络优化、热联合及低温位热利用等手段降低装置综合能耗。",
      "keywords": [
        "换热网络",
        "热联合",
        "夹点"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-能耗"
    },
    {
      "clause_id": "SHT3121-2022-7-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.1",
      "content": "反应器设计应满足化学动力学及传热传质要求，并考虑催化剂装填、再生及更换便利性。",
      "keywords": [
        "反应器",
        "催化剂",
        "动力学"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-设备"
    },
    {
      "clause_id": "SHT3121-2022-7-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.2",
      "content": "塔器设计应进行理论板数、实际板数、塔径及塔高的工艺计算，并校核液泛、雾沫夹带及漏液。",
      "keywords": [
        "塔器",
        "精馏",
        "塔板数",
        "液泛"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-设备"
    },
    {
      "clause_id": "SHT3121-2022-7-3",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.3",
      "content": "换热器选型应根据传热温差、污垢系数及介质腐蚀性确定型式和面积。",
      "keywords": [
        "换热器",
        "LMTD",
        "污垢系数"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-设备"
    },
    {
      "clause_id": "SHT3121-2022-7-4",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.4",
      "content": "泵的选型应满足正常及最小流量工况，并校核 NPSHa 与 NPSHr。",
      "keywords": [
        "泵",
        "NPSH",
        "选型"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-设备"
    },
    {
      "clause_id": "SHT3121-2022-7-5",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "7.5",
      "content": "压缩机选型应明确入口条件、压比、级数及功率，并考虑喘振保护。",
      "keywords": [
        "压缩机",
        "压比",
        "喘振"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-设备"
    },
    {
      "clause_id": "SHT3121-2022-8-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "8.1",
      "content": "对可能超压的设备及管道，应设置安全泄压设施；泄压设计应符合 API 520/521 或等同标准。",
      "keywords": [
        "超压",
        "安全泄压",
        "API520"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504"
      ],
      "category": "SH/T3121-安全泄压"
    },
    {
      "clause_id": "SHT3121-2022-8-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "8.2",
      "content": "安全阀整定压力不应超过被保护设备的设计压力，且应低于连接管道的设计压力。",
      "keywords": [
        "整定压力",
        "设计压力",
        "安全阀"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504"
      ],
      "category": "SH/T3121-安全泄压"
    },
    {
      "clause_id": "SHT3121-2022-8-3",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "8.3",
      "content": "可燃及有毒介质泄放应导入火炬或专用处理系统，不得直接排入大气。",
      "keywords": [
        "火炬",
        "泄放",
        "大气排放"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504"
      ],
      "category": "SH/T3121-安全泄压"
    },
    {
      "clause_id": "SHT3121-2022-8-4",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "8.4",
      "content": "爆破片应与安全阀串联或并联使用时，应明确各自保护场景及更换周期。",
      "keywords": [
        "爆破片",
        "安全阀",
        "串联"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0504"
      ],
      "category": "SH/T3121-安全泄压"
    },
    {
      "clause_id": "SHT3121-2022-9-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "9.1",
      "content": "工艺设计应提出 DCS/PLC 控制总体要求，包括主要控制回路、联锁及紧急停车系统设置原则。",
      "keywords": [
        "DCS",
        "联锁",
        "ESD"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX8248"
      ],
      "category": "SH/T3121-自控"
    },
    {
      "clause_id": "SHT3121-2022-9-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "9.2",
      "content": "关键工艺参数应设高高/低低联锁，联锁动作应安全可靠且便于维护测试。",
      "keywords": [
        "联锁",
        "HH",
        "LL"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX8248"
      ],
      "category": "SH/T3121-自控"
    },
    {
      "clause_id": "SHT3121-2022-9-3",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "9.3",
      "content": "分析仪表取样点设置应代表工艺介质真实组成，并便于维护和安全操作。",
      "keywords": [
        "取样点",
        "分析仪表"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX8248"
      ],
      "category": "SH/T3121-自控"
    },
    {
      "clause_id": "SHT3121-2022-10-1",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "10.1",
      "content": "工艺设计应识别废水、废气及固废来源，提出治理方向及排放指标要求。",
      "keywords": [
        "三废",
        "排放指标"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-环保"
    },
    {
      "clause_id": "SHT3121-2022-10-2",
      "source_type": "standard",
      "source_id": "SH/T 3121-2022",
      "version": "2022",
      "discipline": "PX",
      "clause": "10.2",
      "content": "有毒有害介质设备应设泄漏监测及人员防护设施，并满足职业卫生标准要求。",
      "keywords": [
        "职业卫生",
        "泄漏监测"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX0980",
        "PX3342"
      ],
      "category": "SH/T3121-环保"
    },
    {
      "clause_id": "GB50933-2013-3-1",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "3.1",
      "content": "设计文件应内容完整、深度适当、表达清晰，并符合各阶段审查和施工需要。",
      "keywords": [
        "设计文件",
        "深度"
      ],
      "mandatory": true,
      "skill_tags": [
        "PR-S01",
        "PX8248"
      ],
      "category": "GB50933-基本规定"
    },
    {
      "clause_id": "GB50933-2013-4-1-2",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "4.1.2",
      "content": "工艺设计包应明确工艺技术来源、设计范围及与上下游装置的界面条件。",
      "keywords": [
        "工艺包",
        "界面条件"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2111"
      ],
      "category": "GB50933-工艺包"
    },
    {
      "clause_id": "GB50933-2013-4-2-2",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "4.2.2",
      "content": "工艺设计包 PFD 应表示主要工艺过程、设备、控制方案及主要物流数据。",
      "keywords": [
        "PFD",
        "工艺包"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2111"
      ],
      "category": "GB50933-工艺包"
    },
    {
      "clause_id": "GB50933-2013-4-2-3",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "4.2.3",
      "content": "工艺设计包 P&ID 深度应满足设备订货及长周期设备设计条件提出需要。",
      "keywords": [
        "P&ID",
        "工艺包",
        "长周期设备"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2111"
      ],
      "category": "GB50933-工艺包"
    },
    {
      "clause_id": "GB50933-2013-4-3-2",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "4.3.2",
      "content": "工艺手册应包括工艺原理、正常操作、开停车、异常处理及安全注意事项。",
      "keywords": [
        "工艺手册",
        "操作规程"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2111"
      ],
      "category": "GB50933-工艺包"
    },
    {
      "clause_id": "GB50933-2013-5-3-2",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "5.3.2",
      "content": "基础设计工艺说明书应阐述设计依据、生产规模、工艺方案、物料能量平衡及主要技术经济指标。",
      "keywords": [
        "工艺说明书",
        "基础设计"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2366",
        "PR-S01"
      ],
      "category": "GB50933-基础设计"
    },
    {
      "clause_id": "GB50933-2013-5-3-3",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "5.3.3",
      "content": "基础设计应提交 PFD、P&ID、UID、工艺设备表及工艺设备数据表。",
      "keywords": [
        "基础设计",
        "交付物"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2366",
        "PR-S01"
      ],
      "category": "GB50933-基础设计"
    },
    {
      "clause_id": "GB50933-2013-5-3-4",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "5.3.4",
      "content": "基础设计管道表应包含管段号、介质、设计操作条件、管径、材质及绝热要求。",
      "keywords": [
        "管道表",
        "基础设计"
      ],
      "mandatory": true,
      "skill_tags": [
        "PX2366",
        "PR-S01"
      ],
      "category": "GB50933-基础设计"
    },
    {
      "clause_id": "GB50933-2013-5-3-5",
      "source_type": "standard",
      "source_id": "GB/T 50933-2013",
      "version": "2013",
      "discipline": "PX",
      "clause": "5.3.5",
      "content": "基础设计应编制安全阀、爆破片数据表及火炬系统初步设计条件。",
      "keywords": [

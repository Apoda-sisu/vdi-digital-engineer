      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "6.2.1",
      "content": "不锈钢管道用于腐蚀性介质时，应控制氯离子含量。",
      "keywords": [
        "不锈钢",
        "氯离子"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737"
      ],
      "category": "SH3059"

{
  "seed_version": "pi-phase1",
  "discipline": "piping",
  "description": "Sprint 11-14 管道 Phase1",
  "clauses": [
    {
      "clause_id": "PI-SHT3059-4-1-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.1.1",
      "content": "管道材料等级应根据设计温度、设计压力、介质特性及腐蚀条件确定。",
      "keywords": [
        "材料等级",
        "设计温度",
        "设计压力"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-4-1-2-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.1.2",
      "content": "碳钢管道适用于设计温度不高于 425℃ 且介质无强腐蚀性的场合。",
      "keywords": [
        "碳钢",
        "425",
        "腐蚀性"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-4-2-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.2.1",
      "content": "管道壁厚应满足设计压力、设计温度及腐蚀裕量要求。",
      "keywords": [
        "壁厚",
        "腐蚀裕量"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-4-3-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.3.1",
      "content": "阀门型式应根据介质特性、操作频率及密封要求选用。",
      "keywords": [
        "阀门型式",
        "密封"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP4368"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-4-3-2-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.3.2",
      "content": "高温高压工况宜选用截止阀或闸阀，并满足 SH/T 3059 表要求。",
      "keywords": [
        "截止阀",
        "闸阀",
        "高温"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP4368"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-4-4-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "4.4.1",
      "content": "法兰型式应与管道等级匹配，高压管道宜选用对焊法兰。",
      "keywords": [
        "法兰",
        "对焊"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737",
        "MP4368"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-5-1-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "5.1.1",
      "content": "管道等级表应列出等级号、适用介质、最高 T/P、材质及壁厚系列。",
      "keywords": [
        "等级表",
        "最高温度"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP7737"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-5-2-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "5.2.1",
      "content": "特殊件选用应注明标准号、压力等级及端面型式。",
      "keywords": [
        "特殊件",
        "压力等级"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP4368"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-6-1-1-pi1",
      "source_type": "standard",
      "source_id": "SH/T 3059",
      "version": "2018",
      "discipline": "MP",
      "clause": "6.1.1",
      "content": "埋地管道应选用耐腐蚀材料或加强外防腐。",
      "keywords": [
        "埋地",
        "防腐"
      ],
      "mandatory": true,
      "skill_tags": [
        "MP4038"
      ],
      "category": "SH3059"
    },
    {
      "clause_id": "PI-SHT3059-6-2-1-pi1",

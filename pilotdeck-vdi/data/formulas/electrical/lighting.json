    {
      "formula_id": "EL-LIG-001",
      "name": "照度计算（利用系数法）",
      "name_en": "Illuminance Calculation (Utilization Method)",
      "discipline": "electrical",
      "category": "lighting/illuminance",
      "type": "exact",
      "equation_text": "E = (N * Φ * U * K) / A",
      "equation_latex": "E = \\frac{N \\cdot \\Phi \\cdot U \\cdot K}{A}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "mul", "args": [{"var": "N"}, {"var": "Φ"}, {"var": "U"}, {"var": "K"}]},
        "den": {"var": "A"}
      },
      "variables": [
        {"symbol": "E", "name": "平均照度", "unit": "lx", "role": "output", "desc": "工作面平均照度"},
        {"symbol": "N", "name": "灯具数量", "unit": "-", "role": "input", "constraints": {"min": 1}, "desc": "灯具数量"},
        {"symbol": "Φ", "name": "光源光通量", "unit": "lm", "role": "input", "constraints": {"min": 100}, "desc": "单灯光源光通量"},
        {"symbol": "U", "name": "利用系数", "unit": "-", "role": "input", "constraints": {"min": 0.1, "max": 1}, "desc": "灯具利用系数"},
        {"symbol": "K", "name": "维护系数", "unit": "-", "role": "input", "constraints": {"min": 0.5, "max": 1}, "default": 0.8, "desc": "维护系数"},
        {"symbol": "A", "name": "房间面积", "unit": "m²", "role": "input", "constraints": {"min": 1}, "desc": "房间面积"}
      ],
      "source": {"standard_id": "GB 50034", "clause": "照度计算"},
      "tags": ["照度", "照明计算", "利用系数"],
      "keywords": ["照度计算", "利用系数法", "照明设计"],
      "precision": 1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },

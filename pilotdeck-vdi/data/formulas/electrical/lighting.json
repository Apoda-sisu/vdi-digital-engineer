    {
      "formula_id": "EL-LIG-004",
      "name": "眩光指数计算",
      "name_en": "Glare Index Calculation",
      "discipline": "electrical",
      "category": "lighting/glare",
      "type": "exact",
      "equation_text": "UGR = 8 * lg(Lb * Ω / L²)",
      "equation_latex": "UGR = 8 \\cdot \\log\\left(\\frac{L_b \\cdot \\Omega}{L^2}\\right)",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"const": 8},
          {"op": "log10", "arg": {"op": "div", "num": {"op": "mul", "args": [{"var": "Lb"}, {"var": "Ω"}]}, "den": {"op": "pow", "base": {"var": "L"}, "exp": 2}}}
        ]
      },
      "variables": [
        {"symbol": "UGR", "name": "统一眩光指数", "unit": "-", "role": "output", "desc": "统一眩光评价指数"},
        {"symbol": "Lb", "name": "背景亮度", "unit": "cd/m²", "role": "input", "constraints": {"min": 1}, "desc": "观察者视野内背景亮度"},
        {"symbol": "Ω", "name": "灯具立体角", "unit": "sr", "role": "input", "constraints": {"min": 0.001}, "desc": "灯具在观察者眼中的立体角"},
        {"symbol": "L", "name": "灯具亮度", "unit": "cd/m²", "role": "input", "constraints": {"min": 100}, "desc": "灯具在观察方向的亮度"}
      ],
      "source": {"standard_id": "GB 50034", "clause": "眩光评价"},
      "tags": ["眩光", "照明质量", "UGR"],
      "keywords": ["眩光指数", "UGR", "照明质量"],
      "precision": 0.1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "EL-LIG-005",
      "name": "应急照明持续时间",
      "name_en": "Emergency Lighting Duration",
      "discipline": "electrical",
      "category": "lighting/emergency",
      "type": "exact",
      "equation_text": "t = (C * U) / (P * K)",
      "equation_latex": "t = \\frac{C \\cdot U}{P \\cdot K}",

      },
      "variables": [
        {"symbol": "t", "name": "持续时间", "unit": "h", "role": "output", "desc": "应急照明持续时间"},
        {"symbol": "C", "name": "电池容量", "unit": "Ah", "role": "input", "constraints": {"min": 1}, "desc": "蓄电池容量"},
        {"symbol": "U", "name": "电池电压", "unit": "V", "role": "input", "constraints": {"min": 6}, "desc": "蓄电池电压"},
        {"symbol": "P", "name": "应急照明功率", "unit": "W", "role": "input", "constraints": {"min": 1}, "desc": "应急照明总功率"},
        {"symbol": "K", "name": "放电系数", "unit": "-", "role": "input", "constraints": {"min": 0.5, "max": 1}, "default": 0.8, "desc": "电池放电系数"}

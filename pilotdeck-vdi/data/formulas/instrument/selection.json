    {
      "formula_id": "IN-SEL-005",
      "vdi_formula_id": "IN-SEL-005",
      "name": "流量计压损计算",
      "name_en": "Flowmeter Pressure Loss",
      "discipline": "IN",
      "category": "selection/flowmeter",
      "type": "exact",
      "equation_text": "ΔP = K * (ρ * v²) / 2",
      "equation_latex": "\\Delta P = K \\cdot \\frac{\\rho \\cdot v^2}{2}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {
            "var": "K"
          },
          {
            "op": "div",
            "num": {
              "op": "mul",
              "args": [
                {
                  "var": "ρ"
                },
                {
                  "op": "pow",
                  "base": {
                    "var": "v"
                  },
                  "exp": 2
                }
              ]
            },
            "den": {
              "const": 2
            }
          }
        ]
      },
      "variables": [
        {
          "symbol": "ΔP",
          "name": "压力损失",
          "unit": "Pa",
          "role": "output",
          "desc": "流量计造成的压力损失"
        },
        {
          "symbol": "K",
          "name": "阻力系数",
          "unit": "-",
          "role": "input",
          "constraints": {
            "min": 0.1,
            "max": 100
          },
          "desc": "流量计阻力系数"
        },
        {
          "symbol": "ρ",
          "name": "流体密度",
          "unit": "kg/m³",
          "role": "input",
          "constraints": {
            "min": 0.1,
            "max": 2000
          },
          "desc": "工作状态下流体密度"
        },
        {
          "symbol": "v",
          "name": "流速",
          "unit": "m/s",
          "role": "input",
          "constraints": {
            "min": 0.01,
            "max": 30
          },
          "desc": "管道内流体流速"
        }
      ],
      "source": {
        "standard_id": "GB/T 50770",
        "clause": "流量计选型"
      },
      "tags": [
        "流量计",
        "压力损失",
        "流量测量"
      ],
      "keywords": [

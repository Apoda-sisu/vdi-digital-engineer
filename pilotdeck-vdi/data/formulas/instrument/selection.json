    {
      "formula_id": "IN-SEL-001",
      "vdi_formula_id": "IN-SEL-001",
      "name": "变送器量程选择",
      "name_en": "Transmitter Range Selection",
      "discipline": "IN",
      "category": "selection/transmitter",
      "type": "exact",
      "equation_text": "Range = (Max_Value - Min_Value) * Safety_Factor",
      "equation_latex": "Range = (Max_{value} - Min_{value}) \\cdot Safety_{factor}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {
            "op": "sub",
            "args": [
              {
                "var": "Max_Value"
              },
              {
                "var": "Min_Value"
              }
            ]
          },
          {
            "var": "Safety_Factor"
          }
        ]
      },
      "variables": [
        {
          "symbol": "Range",
          "name": "变送器量程",
          "unit": "-",
          "role": "output",
          "desc": "变送器测量范围"
        },
        {
          "symbol": "Max_Value",
          "name": "最大测量值",
          "unit": "-",
          "role": "input",
          "constraints": {
            "min": 0
          },
          "desc": "工艺参数最大值"
        },
        {
          "symbol": "Min_Value",
          "name": "最小测量值",
          "unit": "-",
          "role": "input",
          "constraints": {
            "min": 0
          },
          "desc": "工艺参数最小值"
        },
        {
          "symbol": "Safety_Factor",
          "name": "安全系数",
          "unit": "-",
          "role": "input",
          "constraints": {
            "min": 1.1,
            "max": 2
          },
          "default": 1.2,
          "desc": "量程安全裕量系数"
        }
      ],
      "source": {
        "standard_id": "GB/T 50770",
        "clause": "变送器选型"
      },
      "tags": [
        "变送器",
        "量程选择",
        "仪表选型"
      ],
      "keywords": [
        "变送器",
        "量程",
        "测量范围"
      ],
      "precision": 0.1,
      "created_at": "2026-06-07T00:00:00Z",
      "updated_at": "2026-06-07T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "IN-SEL-002",
      "vdi_formula_id": "IN-SEL-002",
      "name": "调节阀流量系数（Cv）",
      "name_en": "Control Valve Flow Coefficient",
      "discipline": "IN",
      "category": "selection/valve",
      "type": "exact",
      "equation_text": "Cv = Q * √(SG / ΔP)",
      "equation_latex": "C_v = Q \\cdot \\sqrt{\\frac{SG}{\\Delta P}}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {
            "var": "Q"
          },
          {
            "op": "sqrt",
            "arg": {
              "op": "div",
              "num": {
                "var": "SG"
              },
              "den": {
                "var": "ΔP"
              }
            }
          }
        ]
      },
      "variables": [
        {
          "symbol": "Cv",
          "name": "流量系数",
          "unit": "-",
          "role": "output",
          "desc": "调节阀流量系数"
        },
        {
          "symbol": "Q",
          "name": "体积流量",
          "unit": "m³/h",
          "role": "input",
          "constraints": {
            "min": 0.01,
            "max": 10000
          },
          "desc": "通过阀门的体积流量"
        },
        {
          "symbol": "SG",
          "name": "流体比重",
          "unit": "-",
          "role": "input",
          "constraints": {
            "min": 0.1,
            "max": 10
          },
          "default": 1,
          "desc": "流体相对于水的比重"
        },
        {
          "symbol": "ΔP",
          "name": "阀前后压差",
          "unit": "kPa",
          "role": "input",
          "constraints": {
            "min": 1,
            "max": 10000
          },
          "desc": "阀门前后压力差"
        }
      ],
      "source": {
        "standard_id": "GB/T 50770",
        "clause": "调节阀选型"
      },
      "tags": [
        "调节阀",
        "流量系数",
        "阀门选型"
      ],
      "keywords": [
        "Cv",
        "流量系数",
        "调节阀"
      ],
      "precision": 0.1,
      "created_at": "2026-06-07T00:00:00Z",
      "updated_at": "2026-06-07T00:00:00Z",
      "version": 1

    {
      "formula_id": "IN-SEL-003",
      "vdi_formula_id": "IN-SEL-003",
      "name": "温度传感器响应时间",
      "name_en": "Temperature Sensor Response Time",
      "discipline": "IN",
      "category": "selection/sensor",
      "type": "exact",
      "equation_text": "τ = (m * c) / (h * A)",
      "equation_latex": "\\tau = \\frac{m \\cdot c}{h \\cdot A}",
      "equation_ast": {
        "op": "div",
        "num": {
          "op": "mul",
          "args": [
            {
              "var": "m"
            },
            {
              "var": "c"
            }
          ]
        },
        "den": {
          "op": "mul",
          "args": [
            {
              "var": "h"
            },
            {
              "var": "A"
            }
          ]
        }
      },
      "variables": [
        {
          "symbol": "τ",
          "name": "时间常数",
          "unit": "s",
          "role": "output",
          "desc": "温度传感器响应时间常数"
        },
        {
          "symbol": "m",
          "name": "传感器质量",
          "unit": "kg",
          "role": "input",
          "constraints": {
            "min": 0.001,
            "max": 10
          },
          "desc": "传感器敏感元件质量"
        },
        {
          "symbol": "c",
          "name": "比热容",
          "unit": "J/(kg·K)",
          "role": "input",
          "constraints": {
            "min": 100,
            "max": 5000
          },
          "default": 500,
          "desc": "传感器材料比热容"
        },
        {
          "symbol": "h",
          "name": "传热系数",
          "unit": "W/(m²·K)",
          "role": "input",
          "constraints": {
            "min": 10,
            "max": 10000
          },
          "desc": "传感器与介质间的传热系数"
        },
        {
          "symbol": "A",
          "name": "传热面积",
          "unit": "m²",
          "role": "input",
          "constraints": {
            "min": 0.0001,
            "max": 1
          },
          "desc": "传感器有效传热面积"
        }
      ],
      "source": {
        "standard_id": "GB/T 50770",

    {
      "formula_id": "PI-VOL-002",
      "name": "管道重量计算",
      "name_en": "Pipe Weight Calculation",
      "discipline": "piping",
      "category": "weight",
      "type": "exact",
      "equation_text": "W = π*(D²-d²)/4 * ρ * L",
      "equation_latex": "W = \\frac{\\pi (D^2 - d^2)}{4} \\cdot \\rho \\cdot L",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"const": 0.7854},
          {"op": "sub", "args": [
            {"op": "pow", "base": {"var": "D"}, "exp": 2},
            {"op": "pow", "base": {"var": "d"}, "exp": 2}
          ]},
          {"var": "ρ"},
          {"var": "L"}
        ]
      },
      "variables": [
        {"symbol": "W", "name": "管道重量", "unit": "kg", "role": "output", "desc": "管道重量"},
        {"symbol": "D", "name": "管道外径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "管道外径"},
        {"symbol": "d", "name": "管道内径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "管道内径"},
        {"symbol": "ρ", "name": "材料密度", "unit": "kg/m³", "role": "input", "constraints": {"min": 1000}, "desc": "管材密度"},
        {"symbol": "L", "name": "管道长度", "unit": "m", "role": "input", "constraints": {"min": 0.1}, "desc": "管道长度"}
      ],
      "source": {"standard_id": "GB 50316", "clause": "材料计算"},
      "tags": ["管道重量", "材料计算", "荷载"],
      "keywords": ["管道重量", "管道质量", "材料计算"],
      "precision": 0.1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PI-VOL-003",
      "name": "管道表面积",
      "name_en": "Pipe Surface Area",
      "discipline": "piping",
      "category": "surface",
      "type": "exact",
      "equation_text": "A = π * D * L",
      "equation_latex": "A = \\pi \\cdot D \\cdot L",
      "equation_ast": {
        "op": "mul",
        "args": [{"const": 3.14159}, {"var": "D"}, {"var": "L"}]
      },
      "variables": [
        {"symbol": "A", "name": "表面积", "unit": "m²", "role": "output", "desc": "管道外表面积"},
        {"symbol": "D", "name": "管道外径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "管道外径"},
        {"symbol": "L", "name": "管道长度", "unit": "m", "role": "input", "constraints": {"min": 0.1}, "desc": "管道长度"}
      ],
      "source": {"standard_id": "通用", "clause": "几何计算"},
      "tags": ["表面积", "几何计算", "保温面积"],
      "keywords": ["管道表面积", "外表面积", "保温计算"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PI-VEL-002",
      "name": "蒸汽管道流速",
      "name_en": "Steam Pipe Velocity",
      "discipline": "piping",
      "category": "velocity/steam",
      "type": "exact",
      "equation_text": "V = Q/(ρ*A)",
      "equation_latex": "V = \\frac{Q}{\\rho \\cdot A}",
      "equation_ast": {
        "op": "div",
        "num": {"var": "Q"},
        "den": {"op": "mul", "args": [{"var": "ρ"}, {"var": "A"}]}
      },
      "variables": [
        {"symbol": "V", "name": "流速", "unit": "m/s", "role": "output", "desc": "蒸汽流速"},
        {"symbol": "Q", "name": "质量流量", "unit": "kg/s", "role": "input", "constraints": {"min": 0.001}, "desc": "蒸汽质量流量"},
        {"symbol": "ρ", "name": "蒸汽密度", "unit": "kg/m³", "role": "input", "constraints": {"min": 0.1}, "desc": "蒸汽密度"},
        {"symbol": "A", "name": "管道截面积", "unit": "m²", "role": "input", "constraints": {"min": 0.0001}, "desc": "管道截面积"}
      ],
      "source": {"standard_id": "GB 50316", "clause": "蒸汽管道"},
      "tags": ["蒸汽流速", "蒸汽管道", "流速计算"],
      "keywords": ["蒸汽流速", "蒸汽管道", "质量流量"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PI-VEL-003",
      "name": "两相流流速",
      "name_en": "Two-Phase Flow Velocity",
      "discipline": "piping",
      "category": "velocity/two-phase",
      "type": "exact",
      "equation_text": "Vsg = G/(ρg*A) + G/(ρl*A)",
      "equation_latex": "V_{sg} = \\frac{G}{\\rho_g \\cdot A} + \\frac{G}{\\rho_l \\cdot A}",
      "equation_ast": {
        "op": "add",
        "args": [
          {"op": "div", "num": {"var": "G"}, "den": {"op": "mul", "args": [{"var": "ρg"}, {"var": "A"}]}},
          {"op": "div", "num": {"var": "G"}, "den": {"op": "mul", "args": [{"var": "ρl"}, {"var": "A"}]}}
        ]
      },
      "variables": [
        {"symbol": "Vsg", "name": "表观气速", "unit": "m/s", "role": "output", "desc": "表观气相速度"},
        {"symbol": "G", "name": "质量流量", "unit": "kg/s", "role": "input", "constraints": {"min": 0.001}, "desc": "总质量流量"},
        {"symbol": "ρg", "name": "气相密度", "unit": "kg/m³", "role": "input", "constraints": {"min": 0.1}, "desc": "气相密度"},
        {"symbol": "ρl", "name": "液相密度", "unit": "kg/m³", "role": "input", "constraints": {"min": 100}, "desc": "液相密度"},
        {"symbol": "A", "name": "管道截面积", "unit": "m²", "role": "input", "constraints": {"min": 0.0001}, "desc": "管道截面积"}
      ],
      "source": {"standard_id": "GB 50316", "clause": "两相流"},
      "tags": ["两相流", "气液两相", "流速计算"],
      "keywords": ["两相流", "表观气速", "气液流动"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PI-VEL-004",
      "name": "管道压力降（达西公式）",
      "name_en": "Pipe Pressure Drop (Darcy)",
      "discipline": "piping",
      "category": "pressure/drop",
      "type": "exact",
      "equation_text": "ΔP = f*(L/D)*(ρV²/2)",
      "equation_latex": "\\Delta P = f \\cdot \\frac{L}{D} \\cdot \\frac{\\rho V^2}{2}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"var": "f"},
          {"op": "div", "num": {"var": "L"}, "den": {"var": "D"}},
          {"op": "div", "num": {"op": "mul", "args": [{"var": "ρ"}, {"op": "pow", "base": {"var": "V"}, "exp": 2}]}, "den": {"const": 2}}
        ]
      },
      "variables": [
        {"symbol": "ΔP", "name": "压力降", "unit": "Pa", "role": "output", "desc": "管道沿程压力降"},
        {"symbol": "f", "name": "摩擦因子", "unit": "-", "role": "input", "constraints": {"min": 0.01, "max": 0.1}, "desc": "达西摩擦因子"},
        {"symbol": "L", "name": "管道长度", "unit": "m", "role": "input", "constraints": {"min": 0.1}, "desc": "管道长度"},
        {"symbol": "D", "name": "管道内径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "管道内径"},
        {"symbol": "ρ", "name": "流体密度", "unit": "kg/m³", "role": "input", "constraints": {"min": 100}, "desc": "流体密度"},
        {"symbol": "V", "name": "流速", "unit": "m/s", "role": "input", "constraints": {"min": 0.1}, "desc": "流体流速"}
      ],
      "source": {"standard_id": "GB 50316", "clause": "压力降计算"},
      "tags": ["压力降", "达西公式", "管道阻力"],
      "keywords": ["压力降", "达西公式", "沿程损失"],
      "precision": 1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {

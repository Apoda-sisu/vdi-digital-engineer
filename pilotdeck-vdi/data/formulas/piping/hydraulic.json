        {"symbol": "P_insul", "name": "保温材料价格", "unit": "元/m³", "role": "input", "constraints": {"min": 100}, "desc": "保温材料价格"},
        {"symbol": "ΔT", "name": "温差", "unit": "K", "role": "input", "constraints": {"min": 10}, "desc": "管壁与环境温差"},
        {"symbol": "r1", "name": "管道外半径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "管道外半径"}

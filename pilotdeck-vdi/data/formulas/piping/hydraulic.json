    {
      "formula_id": "PI-VEL-007",
      "name": "管道保温厚度（经济厚度）",
      "name_en": "Economic Insulation Thickness",
      "discipline": "piping",
      "category": "insulation/economic",
      "type": "exact",
      "equation_text": "δ = √(P_heat*t*λ/(P_insul*ΔT)) - r1",
      "equation_latex": "\\delta = \\sqrt{\\frac{P_{heat} \\cdot t \\cdot \\lambda}{P_{insul} \\cdot \\Delta T}} - r_1",
      "equation_ast": {
        "op": "sub",
        "args": [
          {"op": "sqrt", "arg": {"op": "div", "num": {"op": "mul", "args": [{"var": "P_heat"}, {"var": "t"}, {"var": "λ"}]}, "den": {"op": "mul", "args": [{"var": "P_insul"}, {"var": "ΔT"}]}}},
          {"var": "r1"}
        ]
      },
      "variables": [
        {"symbol": "δ", "name": "保温厚度", "unit": "m", "role": "output", "desc": "经济保温厚度"},

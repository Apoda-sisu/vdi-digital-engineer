    {
      "formula_id": "PI-VIB-001",
      "name": "管道固有频率（简支梁）",
      "name_en": "Pipe Natural Frequency (Simply Supported)",
      "discipline": "piping",
      "category": "vibration/natural",
      "type": "exact",
      "equation_text": "fn = (π/2) * √(EI/(m*L⁴))",
      "equation_latex": "f_n = \\frac{\\pi}{2} \\cdot \\sqrt{\\frac{EI}{m \\cdot L^4}}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"const": 1.5708},
          {"op": "sqrt", "arg": {"op": "div", "num": {"op": "mul", "args": [{"var": "E"}, {"var": "I"}]}, "den": {"op": "mul", "args": [{"var": "m"}, {"op": "pow", "base": {"var": "L"}, "exp": 4}]}}}
        ]
      },
      "variables": [
        {"symbol": "fn", "name": "固有频率", "unit": "Hz", "role": "output", "desc": "管道一阶固有频率"},
        {"symbol": "E", "name": "弹性模量", "unit": "Pa", "role": "input", "constraints": {"min": 1e9}, "desc": "材料弹性模量"},
        {"symbol": "I", "name": "截面惯性矩", "unit": "m⁴", "role": "input", "constraints": {"min": 1e-10}, "desc": "管道截面惯性矩"},
        {"symbol": "m", "name": "单位长度质量", "unit": "kg/m", "role": "input", "constraints": {"min": 0.1}, "desc": "管道单位长度质量（含介质）"},
        {"symbol": "L", "name": "跨距", "unit": "m", "role": "input", "constraints": {"min": 0.5, "max": 20}, "desc": "管道支架跨距"}
      ],
      "source": {"standard_id": "GB/T 20801.3", "clause": "振动分析"},
      "tags": ["固有频率", "管道振动", "共振"],
      "keywords": ["固有频率", "管道振动", "共振频率"],
      "precision": 0.1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {

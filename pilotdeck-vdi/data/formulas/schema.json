{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vdi-formula-v1",
  "title": "VDI 公式库公式实体",
  "description": "VDI 工程计算公式的结构化数据模型",
  "type": "object",
  "required": ["formula_id", "name", "discipline", "category", "equation_text", "variables", "source"],
  "properties": {
    "formula_id": {
      "type": "string",
      "pattern": "^[A-Z]{2}-[A-Z]{3}-[0-9]{3}$",
      "description": "公式唯一ID，格式：{专业码}-{类别码}-{序号}"
    },
    "name": {
      "type": "string",
      "description": "公式中文名称"
    },
    "name_en": {
      "type": "string",
      "description": "公式英文名称"
    },
    "discipline": {
      "type": "string",
      "enum": ["water", "process", "piping", "electrical", "instrument", "hse", "equipment", "general"],
      "description": "所属专业"
    },
    "category": {
      "type": "string",
      "description": "公式类别路径，如 hydraulic/pipe_friction"
    },
    "type": {
      "type": "string",
      "enum": ["exact", "empirical", "approximation", "lookup"],
      "default": "exact",
      "description": "公式类型：exact=精确公式, empirical=经验公式, approximation=近似公式, lookup=查表"
    },
    "equation_text": {
      "type": "string",
      "description": "公式文本表达式，供人阅读"
    },
    "equation_latex": {
      "type": "string",
      "description": "LaTeX 格式公式"
    },
    "equation_ast": {
      "type": "object",
      "description": "抽象语法树，供程序解析执行",
      "properties": {
        "op": { "type": "string" },
        "args": { "type": "array" },
        "var": { "type": "string" },
        "const": { "type": "number" },
        "base": { "type": "object" },
        "exp": { "type": "number" }
      }
    },
    "variables": {
      "type": "array",
      "description": "公式变量定义",
      "items": {
        "type": "object",
        "required": ["symbol", "name", "unit", "role"],
        "properties": {
          "symbol": { "type": "string", "description": "变量符号" },
          "name": { "type": "string", "description": "变量中文名" },
          "unit": { "type": "string", "description": "单位" },
          "role": { "type": "string", "enum": ["input", "output", "intermediate"], "description": "角色" },
          "desc": { "type": "string", "description": "描述" },
          "constraints": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "exclusive_min": { "type": "boolean" },
              "exclusive_max": { "type": "boolean" }
            }
          },
          "default": { "description": "默认值" },
          "alt_units": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "unit": { "type": "string" },
                "factor": { "type": "number" },
                "offset": { "type": "number" },
                "lookup": { "type": "string" }
              }
            }
          },
          "look_up": {
            "type": "object",
            "description": "查表引用",
            "properties": {
              "type": { "type": "string" },
              "table_ref": { "type": "string" },
              "column": { "type": "string" },
              "key_column": { "type": "string" }
            }
          }
        }
      }
    },
    "coefficients": {
      "type": "array",
      "description": "经验系数/修正系数",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "symbol": { "type": "string" },
          "range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
          "default": { "type": "number" },
          "condition": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["standard_id", "clause"],
      "properties": {
        "standard_id": { "type": "string", "description": "来源规范编号" },
        "clause": { "type": "string", "description": "条款号" },
        "page": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "applicable_scope": {
      "type": "object",
      "description": "适用范围",
      "properties": {
        "pipe_types": { "type": "array", "items": { "type": "string" } },
        "flow_regimes": { "type": "array", "items": { "type": "string" } },
        "materials": { "type": "array", "items": { "type": "string" } },
        "exclusions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "related_formulas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "formula_id": { "type": "string" },
          "relation": { "type": "string", "enum": ["special_case", "complement", "alternative", "prerequisite"] },
          "note": { "type": "string" }
        }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "precision": { "type": "string", "enum": ["精确", "估算", "近似"], "default": "精确" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "置信度（经验公式用）" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "version": { "type": "number" }
  }
}

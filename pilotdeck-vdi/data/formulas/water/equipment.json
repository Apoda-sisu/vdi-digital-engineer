  "formulas": [
    {
      "formula_id": "WA-EQ-001",
      "name": "水泵轴功率",
      "name_en": "Pump Shaft Power",
      "discipline": "water",
      "category": "equipment/pump",
      "type": "exact",
      "equation_text": "P = ρ * g * Q * H / (1000 * η)",
      "equation_latex": "P = \\frac{\\rho \\cdot g \\cdot Q \\cdot H}{1000 \\cdot \\eta}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "mul", "args": [{"var": "ρ"}, {"var": "g"}, {"var": "Q"}, {"var": "H"}]},
        "den": {"op": "mul", "args": [{"const": 1000}, {"var": "η"}]}
      },
      "variables": [
        {"symbol": "P", "name": "水泵轴功率", "unit": "kW", "role": "output", "desc": "水泵轴功率"},
        {"symbol": "ρ", "name": "液体密度", "unit": "kg/m3", "role": "input", "default": 1000, "desc": "清水密度1000kg/m3"},
        {"symbol": "g", "name": "重力加速度", "unit": "m/s2", "role": "input", "default": 9.81},
        {"symbol": "Q", "name": "流量", "unit": "m3/s", "role": "input", "constraints": {"min": 0, "exclusive_min": true},
          "alt_units": [{"unit": "m3/h", "factor": 0.000278}, {"unit": "L/s", "factor": 0.001}]},
        {"symbol": "H", "name": "扬程", "unit": "m", "role": "input", "constraints": {"min": 0, "exclusive_min": true},
          "desc": "水泵总扬程"},
        {"symbol": "η", "name": "水泵效率", "unit": "-", "role": "input", "constraints": {"min": 0.1, "max": 1.0},
          "desc": "水泵效率，一般取0.6-0.85"}
      ],
      "source": {"standard_id": "GB 50015-2019", "clause": "3.8.8"},
      "related_formulas": [
        {"formula_id": "WA-EQ-002", "relation": "complement", "note": "电机功率=轴功率/电机效率"}
      ],
      "tags": ["水泵", "轴功率", "选型"],
      "keywords": ["水泵功率", "轴功率", "泵功率计算", "P=ρgQH/η"],
      "precision": "精确",
      "created_at": "2026-06-04T00:00:00Z",
      "updated_at": "2026-06-04T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "WA-EQ-002",
      "name": "水泵电机功率",
      "name_en": "Pump Motor Power",
      "discipline": "water",
      "category": "equipment/pump",
      "type": "exact",
      "equation_text": "Pm = P / ηm",
      "equation_latex": "P_m = \\frac{P}{\\eta_m}",
      "equation_ast": {"op": "div", "num": {"var": "P"}, "den": {"var": "ηm"}},
      "variables": [
        {"symbol": "Pm", "name": "电机功率", "unit": "kW", "role": "output", "desc": "配套电机功率"},
        {"symbol": "P", "name": "水泵轴功率", "unit": "kW", "role": "input"},
        {"symbol": "ηm", "name": "电机效率", "unit": "-", "role": "input", "default": 0.9,
          "desc": "电机效率，一般取0.85-0.95"}
      ],
      "source": {"standard_id": "GB 50015-2019", "clause": "3.8.8"},
      "related_formulas": [{"formula_id": "WA-EQ-001", "relation": "prerequisite", "note": "需先计算轴功率"}],
      "tags": ["水泵", "电机功率", "选型"],
      "keywords": ["电机功率", "配套功率", "水泵选型"],
      "precision": "精确",
      "created_at": "2026-06-04T00:00:00Z",
      "updated_at": "2026-06-04T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "WA-EQ-003",
      "name": "水泵汽蚀余量校核",
      "name_en": "Pump NPSH Verification",
      "discipline": "water",
      "category": "equipment/pump",
      "type": "exact",
      "equation_text": "NPSHa = Ha + Hs - Hv - Hf_s",
      "equation_latex": "NPSH_a = H_a + H_s - H_v - H_{f,s}",
      "equation_ast": {
        "op": "sub",
        "args": [
          {"op": "add", "args": [{"var": "Ha"}, {"var": "Hs"}]},
          {"op": "add", "args": [{"var": "Hv"}, {"var": "Hf_s"}]}
        ]
      },
      "variables": [
        {"symbol": "NPSHa", "name": "有效汽蚀余量", "unit": "m", "role": "output", "desc": "系统可用的有效汽蚀余量"},
        {"symbol": "Ha", "name": "大气压力水头", "unit": "m", "role": "input", "default": 10.33, "desc": "当地大气压对应的水柱高度"},
        {"symbol": "Hs", "name": "吸水几何高度", "unit": "m", "role": "input", "desc": "液面至泵入口的垂直高度（灌注为正，吸上为负）"},
        {"symbol": "Hv", "name": "饱和蒸汽压力水头", "unit": "m", "role": "input", "desc": "液体饱和蒸汽压对应的水柱高度",
          "look_up": {"type": "fluid_property", "table_ref": "TBL-HV-001", "default": 0.24}},
        {"symbol": "Hf_s", "name": "吸入管路损失", "unit": "m", "role": "input", "constraints": {"min": 0}, "desc": "吸入管路的水头损失"}
      ],
      "source": {"standard_id": "GB 50015-2019", "clause": "3.8.6", "note": "水泵安装高度确定"},
      "applicable_scope": {
        "conditions": ["NPSHa ≥ 1.3 × NPSHr"],
        "exclusions": ["自灌式吸水"]
      },
      "related_formulas": [
        {"formula_id": "WA-EQ-001", "relation": "complement", "note": "水泵选型"}
      ],
      "tags": ["汽蚀余量", "NPSH", "水泵安装高度", "吸上高度"],
      "keywords": ["汽蚀余量", "NPSH", "有效汽蚀余量", "水泵安装高度", "吸上真空度"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "WA-EQ-004",
      "name": "变频水泵功率曲线",
      "name_en": "Variable Frequency Pump Power Curve",
      "discipline": "water",
      "category": "equipment/pump",
      "type": "exact",
      "equation_text": "P2 = P1 * (n2/n1)³ (相似工况)",
      "equation_latex": "P_2 = P_1 \\cdot \\left(\\frac{n_2}{n_1}\\right)^3",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"var": "P1"},
          {
            "op": "pow",
            "base": {
              "op": "div",
              "num": {"var": "n2"},
              "den": {"var": "n1"}
            },
            "exp": {"const": 3}
          }
        ]
      },
      "variables": [
        {"symbol": "P2", "name": "调速后功率", "unit": "kW", "role": "output", "desc": "变频调速后的水泵功率"},
        {"symbol": "P1", "name": "额定功率", "unit": "kW", "role": "input", "constraints": {"min": 0.1}, "desc": "额定转速下的水泵功率"},
        {"symbol": "n2", "name": "调速后转速", "unit": "rpm", "role": "input", "constraints": {"min": 600, "max": 3600}, "desc": "变频调速后的转速"},
        {"symbol": "n1", "name": "额定转速", "unit": "rpm", "role": "input", "constraints": {"min": 600, "max": 3600}, "default": 2950, "desc": "水泵额定转速"}
      ],
      "source": {"standard_id": "GB 50015-2019", "clause": "3.8.11", "note": "变频调速水泵选型"},
      "applicable_scope": {
        "conditions": ["相似工况点"],
        "exclusions": ["非相似工况"]
      },
      "related_formulas": [
        {"formula_id": "WA-EQ-001", "relation": "prerequisite", "note": "额定功率计算"}
      ],
      "tags": ["变频泵", "功率曲线", "相似定律", "节能"],
      "keywords": ["变频水泵", "功率曲线", "相似定律", "调速节能", "水泵效率"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {

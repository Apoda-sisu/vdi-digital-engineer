    {
      "formula_id": "WA-HYD-006",
      "name": "达西-魏斯巴赫沿程水头损失",
      "name_en": "Darcy-Weisbach Equation",
      "discipline": "water",
      "category": "hydraulic/pipe_friction",
      "type": "exact",
      "equation_text": "Hf = f * (L/D) * (V^2 / (2*g))",
      "equation_latex": "H_f = f \\cdot \\frac{L}{D} \\cdot \\frac{V^2}{2g}",
      "equation_ast": {
        "op": "mul",
        "args": [
          {"var": "f"},
          {"op": "div", "num": {"var": "L"}, "den": {"var": "D"}},
          {"op": "div",
            "num": {"op": "pow", "base": {"var": "V"}, "exp": 2},
            "den": {"op": "mul", "args": [{"const": 2}, {"var": "g"}]}
          }
        ]
      },
      "variables": [
        {"symbol": "Hf", "name": "沿程水头损失", "unit": "m", "role": "output"},
        {"symbol": "f", "name": "达西摩擦系数", "unit": "-", "role": "input", "desc": "与雷诺数和管壁粗糙度有关"},
        {"symbol": "L", "name": "管道长度", "unit": "m", "role": "input"},
        {"symbol": "D", "name": "管径", "unit": "m", "role": "input"},
        {"symbol": "V", "name": "流速", "unit": "m/s", "role": "input"},
        {"symbol": "g", "name": "重力加速度", "unit": "m/s2", "role": "input", "default": 9.81}
      ],
      "source": {"standard_id": "GB 50013-2018", "clause": "7.1.3", "note": "条文说明中的通用公式"},
      "related_formulas": [{"formula_id": "WA-HYD-001", "relation": "alternative", "note": "海曾-威廉姆斯为简化形式"}],
      "tags": ["达西公式", "沿程损失", "摩擦系数"],
      "keywords": ["Darcy-Weisbach", "达西", "摩擦系数", "沿程损失"],
      "precision": "精确",
      "created_at": "2026-06-04T00:00:00Z",
      "updated_at": "2026-06-04T00:00:00Z",
      "version": 1

    {
      "formula_id": "PR-REA-001",
      "name": "理想气体状态方程",
      "name_en": "Ideal Gas Law",
      "discipline": "process",
      "category": "reaction",
      "type": "equation",
      "equation_text": "PV = nRT → V = n*R*T/P",
      "equation_latex": "V = \\frac{nRT}{P}",
      "equation_ast": {
        "op": "div",
        "num": {
          "op": "mul",
          "args": [{"var": "n"}, {"var": "R"}, {"var": "T"}]
        },
        "den": {"var": "P"}
      },
      "variables": [
        {
          "symbol": "V",
          "name": "体积",
          "role": "output",
          "unit": "m3",
          "desc": "气体体积"
        },
        {
          "symbol": "n",
          "name": "物质的量",
          "role": "input",
          "unit": "mol",
          "desc": "气体的物质的量"
        },
        {
          "symbol": "R",
          "name": "气体常数",
          "role": "constant",
          "unit": "J/(mol*K)",
          "default": 8.314,
          "desc": "理想气体常数"
        },
        {
          "symbol": "T",
          "name": "温度",
          "role": "input",
          "unit": "K",
          "desc": "绝对温度"
        },
        {
          "symbol": "P",
          "name": "压力",
          "role": "input",
          "unit": "Pa",
          "desc": "气体压力"
        }
      ],
      "source": {"standard_id": "化工原理通用公式", "clause": "通用"},
      "tags": ["气体", "状态方程", "热力学"],
      "keywords": ["理想气体", "PV=nRT", "体积", "压力", "温度"],
      "precision": 6,
      "created_at": "2026-06-04T00:00:00Z",
      "updated_at": "2026-06-04T00:00:00Z",
      "version": 1
    },

      "name": "干燥速率方程",
      "name_en": "Drying Rate Equation",
      "discipline": "process",
      "category": "separation/drying",
      "type": "exact",
      "equation_text": "N = Gc * dX / (A * dθ)",
      "equation_latex": "N = \\frac{G_c \\cdot dX}{A \\cdot d\\theta}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "mul", "args": [{"var": "Gc"}, {"var": "dX"}]},
        "den": {"op": "mul", "args": [{"var": "A"}, {"var": "dθ"}]}
      },
      "variables": [
        {"symbol": "N", "name": "干燥速率", "unit": "kg/(m²·s)", "role": "output", "desc": "单位面积干燥速率"},
        {"symbol": "Gc", "name": "绝干物料量", "unit": "kg", "role": "input", "constraints": {"min": 0.001}, "desc": "绝干物料质量"},
        {"symbol": "dX", "name": "含水量变化", "unit": "kg/kg", "role": "input", "desc": "物料含水量变化"},
        {"symbol": "A", "name": "干燥面积", "unit": "m²", "role": "input", "constraints": {"min": 0.001}, "desc": "物料干燥面积"},
        {"symbol": "dθ", "name": "时间变化", "unit": "s", "role": "input", "constraints": {"min": 0.001}, "desc": "时间间隔"}
      ],
      "source": {"standard_id": "化工原理", "clause": "干燥"},
      "tags": ["干燥", "干燥速率", "物料干燥"],
      "keywords": ["干燥速率", "干燥计算", "含水量"],
      "precision": 0.0001,

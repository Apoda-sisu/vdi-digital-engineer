      "version": 1
    },
    {
      "formula_id": "PR-SEP-005",
      "name": "过滤速率方程（达西定律）",
      "name_en": "Filtration Rate (Darcy's Law)",
      "discipline": "process",
      "category": "separation/filtration",
      "type": "exact",
      "equation_text": "Q = A * ΔP / (μ * R)",
      "equation_latex": "Q = \\frac{A \\cdot \\Delta P}{\\mu \\cdot R}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "mul", "args": [{"var": "A"}, {"var": "ΔP"}]},
        "den": {"op": "mul", "args": [{"var": "μ"}, {"var": "R"}]}
      },
      "variables": [
        {"symbol": "Q", "name": "过滤速率", "unit": "m³/s", "role": "output", "desc": "滤液流量"},
        {"symbol": "A", "name": "过滤面积", "unit": "m²", "role": "input", "constraints": {"min": 0.001}, "desc": "过滤面积"},
        {"symbol": "ΔP", "name": "过滤压差", "unit": "Pa", "role": "input", "constraints": {"min": 1000}, "desc": "过滤推动力"},
        {"symbol": "μ", "name": "滤液粘度", "unit": "Pa·s", "role": "input", "constraints": {"min": 1e-6}, "desc": "滤液动力粘度"},
        {"symbol": "R", "name": "滤饼阻力", "unit": "1/m", "role": "input", "constraints": {"min": 1e6}, "desc": "滤饼比阻"}
      ],
      "source": {"standard_id": "化工原理", "clause": "过滤"},
      "tags": ["过滤", "达西定律", "滤饼"],
      "keywords": ["过滤速率", "达西定律", "滤饼阻力"],
      "precision": 0.001,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PR-SEP-006",
      "name": "离心分离因数",
      "name_en": "Centrifugal Separation Factor",
      "discipline": "process",
      "category": "separation/centrifuge",
      "type": "exact",
      "equation_text": "α = ω²R/g = n²π²R/(900g)",
      "equation_latex": "\\alpha = \\frac{\\omega^2 R}{g} = \\frac{n^2 \\pi^2 R}{900g}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "mul", "args": [
          {"op": "pow", "base": {"var": "n"}, "exp": 2},
          {"const": 9.8696},
          {"var": "R"}
        ]},
        "den": {"op": "mul", "args": [{"const": 900}, {"var": "g"}]}
      },
      "variables": [
        {"symbol": "α", "name": "分离因数", "unit": "-", "role": "output", "desc": "离心分离因数"},
        {"symbol": "n", "name": "转速", "unit": "rpm", "role": "input", "constraints": {"min": 100}, "desc": "离心机转速"},
        {"symbol": "R", "name": "转鼓半径", "unit": "m", "role": "input", "constraints": {"min": 0.01}, "desc": "离心机转鼓半径"},
        {"symbol": "g", "name": "重力加速度", "unit": "m/s²", "role": "constant", "default": 9.81, "desc": "重力加速度"}
      ],
      "source": {"standard_id": "化工原理", "clause": "离心分离"},
      "tags": ["离心分离", "分离因数", "离心机"],
      "keywords": ["离心分离", "分离因数", "离心机选型"],

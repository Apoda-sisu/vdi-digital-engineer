    {
      "formula_id": "PR-SEP-001",
      "name": "精馏塔理论板数（McCabe-Thiele法）",
      "name_en": "Distillation Theoretical Plates",
      "discipline": "process",
      "category": "separation/distillation",
      "type": "exact",
      "equation_text": "N = ln[(xD/(1-xD)) * ((1-xB)/xB)] / ln(α)",
      "equation_latex": "N = \\frac{\\ln\\left[\\frac{x_D}{1-x_D} \\cdot \\frac{1-x_B}{x_B}\\right]}{\\ln(\\alpha)}",
      "equation_ast": {
        "op": "div",
        "num": {"op": "log", "arg": {"op": "mul", "args": [
          {"op": "div", "num": {"var": "xD"}, "den": {"op": "sub", "args": [{"const": 1}, {"var": "xD"}]}},
          {"op": "div", "num": {"op": "sub", "args": [{"const": 1}, {"var": "xB"}]}, "den": {"var": "xB"}}
        ]}},
        "den": {"op": "log", "arg": {"var": "α"}}
      },
      "variables": [
        {"symbol": "N", "name": "理论板数", "unit": "-", "role": "output", "desc": "最小理论板数"},
        {"symbol": "xD", "name": "馏出液组成", "unit": "-", "role": "input", "constraints": {"min": 0.01, "max": 0.99}, "desc": "馏出液中轻组分摩尔分数"},
        {"symbol": "xB", "name": "釜液组成", "unit": "-", "role": "input", "constraints": {"min": 0.01, "max": 0.99}, "desc": "釜液中轻组分摩尔分数"},
        {"symbol": "α", "name": "相对挥发度", "unit": "-", "role": "input", "constraints": {"min": 1.01}, "desc": "轻重组分相对挥发度"}
      ],
      "source": {"standard_id": "化工原理", "clause": "蒸馏"},
      "tags": ["精馏", "理论板数", "McCabe-Thiele"],
      "keywords": ["精馏塔", "理论板数", "McCabe-Thiele", "相对挥发度"],
      "precision": 0.1,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PR-SEP-002",
      "name": "吸收塔高度计算",
      "name_en": "Absorption Tower Height",
      "discipline": "process",
      "category": "separation/absorption",
      "type": "exact",
      "equation_text": "H = HETP * NT",
      "equation_latex": "H = HETP \\cdot N_T",
      "equation_ast": {
        "op": "mul",
        "args": [{"var": "HETP"}, {"var": "NT"}]
      },
      "variables": [
        {"symbol": "H", "name": "塔高", "unit": "m", "role": "output", "desc": "吸收塔填料层高度"},
        {"symbol": "HETP", "name": "理论板当量高度", "unit": "m", "role": "input", "constraints": {"min": 0.1, "max": 2}, "desc": "每块理论板对应的填料高度"},
        {"symbol": "NT", "name": "理论板数", "unit": "-", "role": "input", "constraints": {"min": 1}, "desc": "所需理论板数"}
      ],
      "source": {"standard_id": "化工原理", "clause": "吸收"},
      "tags": ["吸收塔", "填料塔", "HETP"],
      "keywords": ["吸收塔高度", "HETP", "填料塔设计"],
      "precision": 0.01,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PR-SEP-003",
      "name": "萃取分配系数",
      "name_en": "Extraction Distribution Coefficient",
      "discipline": "process",
      "category": "separation/extraction",
      "type": "exact",
      "equation_text": "K = C_extract / C_raffinate",
      "equation_latex": "K = \\frac{C_{extract}}{C_{raffinate}}",
      "equation_ast": {
        "op": "div",
        "num": {"var": "C_extract"},
        "den": {"var": "C_raffinate"}
      },
      "variables": [
        {"symbol": "K", "name": "分配系数", "unit": "-", "role": "output", "desc": "萃取分配系数"},
        {"symbol": "C_extract", "name": "萃取相浓度", "unit": "kg/m³", "role": "input", "constraints": {"min": 0}, "desc": "萃取相中溶质浓度"},
        {"symbol": "C_raffinate", "name": "萃余相浓度", "unit": "kg/m³", "role": "input", "constraints": {"min": 0}, "desc": "萃余相中溶质浓度"}
      ],
      "source": {"standard_id": "化工原理", "clause": "萃取"},
      "tags": ["萃取", "分配系数", "液液萃取"],
      "keywords": ["萃取", "分配系数", "液液萃取"],
      "precision": 0.001,
      "created_at": "2026-06-05T00:00:00Z",
      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {

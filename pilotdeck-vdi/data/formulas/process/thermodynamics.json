      "updated_at": "2026-06-05T00:00:00Z",
      "version": 1
    },
    {
      "formula_id": "PR-VAP-003",
      "name": "道尔顿分压定律",
      "name_en": "Dalton's Law of Partial Pressures",
      "discipline": "process",
      "category": "thermodynamics/gas",
      "type": "exact",
      "equation_text": "P_total = P1 + P2 + ... + Pn",
      "equation_latex": "P_{total} = \\sum_{i=1}^{n} P_i",
      "equation_ast": {
        "op": "add",
        "args": [{"var": "P1"}, {"var": "P2"}, {"var": "P3"}]
      },
      "variables": [
        {"symbol": "P_total", "name": "总压", "unit": "Pa", "role": "output", "desc": "混合气体总压力"},
        {"symbol": "P1", "name": "组分1分压", "unit": "Pa", "role": "input", "constraints": {"min": 0}, "desc": "组分1的分压"},
        {"symbol": "P2", "name": "组分2分压", "unit": "Pa", "role": "input", "constraints": {"min": 0}, "desc": "组分2的分压"},
        {"symbol": "P3", "name": "组分3分压", "unit": "Pa", "role": "input", "constraints": {"min": 0}, "desc": "组分3的分压"}
      ],
      "source": {"standard_id": "化工原理", "clause": "气体混合物"},
      "tags": ["道尔顿定律", "分压", "气体混合物"],
      "keywords": ["道尔顿分压定律", "总压", "分压", "气体混合"],
      "precision": 0.01,

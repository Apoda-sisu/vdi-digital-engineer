        "output_type",
        "payload",
        "citations",
        "risk_level",
        "confidence",
        "status"
      ],
      "note": "output_type 枚举: instrument_design / instrument_index / control_loop / interlock / dcs_config / control_valve_spec / instrument_installation / analytical_instruments / instrument_network",
      "sub_discipline_contracts": {

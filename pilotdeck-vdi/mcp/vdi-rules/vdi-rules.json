{
  "version": "0.1.0",
  "description": "VDI 红线规则与校审闸门定义",
  "redlines": [
    {
      "id": "RL-001",
      "name": "消防设计合规",
      "description": "消防给水系统必须符合 GB 50974-2014 和 GB 50016-2014 的要求",
      "discipline": [
        "CI",
        "HX"
      ],
      "severity": "critical",
      "check": "输出中消防水量、消火栓布置、消防水池有效容积必须满足规范最低要求",
      "standard_refs": [
        "GB 50974-2014",
        "GB 50016-2014 §3.3"
      ]
    },
    {
      "id": "RL-002",
      "name": "防火间距合规",
      "description": "建筑物防火间距必须符合 GB 50016-2014 的规定",
      "discipline": [
        "CB",
        "SI",
        "MP"
      ],
      "severity": "critical",
      "check": "总图布置中相邻建筑间距不得小于规范要求的防火间距最小值",
      "standard_refs": [
        "GB 50016-2014 §3.4"
      ]
    },
    {
      "id": "RL-003",
      "name": "防爆分区合规",
      "description": "爆炸危险区域划分必须符合 GB 50058-2014",
      "discipline": [
        "EA",
        "PX"
      ],
      "severity": "critical",
      "check": "电气设备选型与防爆分区等级一致，爆炸危险区域图必须标注",
      "standard_refs": [
        "GB 50058-2014"
      ]
    },
    {
      "id": "RL-004",
      "name": "HAZOP 建议闭环",
      "description": "HAZOP/LOPA 分析建议必须在设计中闭环",
      "discipline": [
        "PX",
        "IN",
        "HS"
      ],
      "severity": "critical",
      "check": "所有 HAZOP 建议项状态不得为 open，关闭率必须达到 100%",
      "standard_refs": [
        "AQ/T 3049-2013"
      ]
    },
    {
      "id": "RL-005",
      "name": "排污水质达标",
      "description": "排水水质必须满足排放标准或预处理要求",
      "discipline": [
        "CI",
        "HS"
      ],
      "severity": "critical",
      "check": "废水排放水质必须满足 GB 8978-1996 或项目环评批复要求",
      "standard_refs": [
        "GB 8978-1996"
      ]
    },
    {
      "id": "RL-006",
      "name": "安全阀泄放合规",
      "description": "安全阀泄放系统设计必须符合规范",
      "discipline": [
        "PX",
        "MP",
        "HS"
      ],
      "severity": "critical",
      "check": "安全阀设定压力、泄放量、排放去向必须符合规范要求",
      "standard_refs": [
        "GB/T 12241-2021",
        "API 520"
      ]
    },
    {
      "id": "RL-007",
      "name": "证据链完整性",
      "description": "所有设计结论必须附带规范依据引用（citations）",
      "discipline": [
        "*"
      ],
      "severity": "high",
      "check": "DisciplineOutput 的 citations 字段不得为空，每条引用含 source_type/source_id/version/clause",
      "standard_refs": [
        "VDI-RED-002"
      ]
    }
  ],
  "review_gates": {
    "design": {
      "after": "设计人提交",
      "checks": [
        {
          "id": "DS-01",
          "item": "设计计算正确性",
          "weight": "critical"
        },
        {
          "id": "DS-02",
          "item": "图纸与计算书一致性",
          "weight": "high"
        },
        {
          "id": "DS-03",
          "item": "规范选用正确性",
          "weight": "high"
        },
        {
          "id": "DS-04",
          "item": "设计文件完整性（说明书/计算书/图纸/数据表）",
          "weight": "high"
        },
        {
          "id": "DS-05",
          "item": "自校记录完整性",
          "weight": "medium"
        }
      ],
      "pass_condition": "all_critical_passed AND high_failure_rate < 0.2"
    },
    "checking": {
      "after": "设计人自校",
      "performed_by": "校核人",
      "checks": [
        {
          "id": "CK-01",
          "item": "设计计算正确性校核",
          "weight": "critical"
        },
        {
          "id": "CK-02",
          "item": "设计文件完整性校核",
          "weight": "high"
        },
        {
          "id": "CK-03",
          "item": "规范符合性校核",
          "weight": "critical"
        },
        {
          "id": "CK-04",
          "item": "证据链校核（citations 有效性）",
          "weight": "high"
        },
        {
          "id": "CK-05",
          "item": "与上游输入条件一致性",
          "weight": "high"
        },
        {
          "id": "CK-06",
          "item": "红线规则符合性",
          "weight": "critical"
        }
      ],
      "pass_condition": "all_critical_passed AND high_failure_rate < 0.1"
    },
    "review": {
      "after": "校核通过",
      "performed_by": "审核人",
      "checks": [
        {
          "id": "RV-01",
          "item": "技术方案合理性审核",
          "weight": "critical"
        },
        {
          "id": "RV-02",
          "item": "设计原则正确性审核",
          "weight": "critical"
        },
        {
          "id": "RV-03",
          "item": "系统间协调性审核",
          "weight": "high"
        },
        {
          "id": "RV-04",
          "item": "上下游接口匹配审核",
          "weight": "high"
        },
        {
          "id": "RV-05",
          "item": "设计参数经济合理性",
          "weight": "medium"
        },
        {
          "id": "RV-06",
          "item": "可施工性审核",
          "weight": "medium"
        }
      ],
      "pass_condition": "all_critical_passed AND high_failure_rate < 0.1"
    },
    "approval": {
      "after": "审核通过（仅重大方案需要）",
      "performed_by": "审定人",
      "checks": [
        {
          "id": "AP-01",
          "item": "设计指导思想审定",
          "weight": "critical"
        },
        {
          "id": "AP-02",
          "item": "技术路线审定",
          "weight": "critical"
        },
        {
          "id": "AP-03",
          "item": "重大方案可行性审定",
          "weight": "critical"
        },
        {
          "id": "AP-04",
          "item": "设计阶段成果审定",
          "weight": "high"
        },
        {
          "id": "AP-05",
          "item": "生产过程合规性审查",
          "weight": "high"
        }
      ],
      "pass_condition": "all_critical_passed"
    }
  },
  "output_contracts": {

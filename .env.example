# VDI 数字工程师环境变量配置

# 应用配置
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# 数据库配置
POSTGRES_DB=vdi_db
POSTGRES_USER=vdi_user
POSTGRES_PASSWORD=vdi_postgres_2026

# Redis 配置
REDIS_PASSWORD=vdi_redis_2026

# JWT 密钥
JWT_SECRET=your_jwt_secret_here

# API 密钥
API_KEY=your_api_key_here

# 邮件配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 图片解读（vdi-vision）— 本地 / 云端切换
# VISION_PROVIDER: openai（云端）| ollama（本地）
VISION_PROVIDER=openai
VISION_API_KEY=
VISION_API_BASE=
VISION_MODEL_OPENAI=gpt-4o-mini
VISION_MODEL_OLLAMA=llava
# Docker 容器访问宿主机 Ollama 时使用 host.docker.internal
OLLAMA_BASE=http://127.0.0.1:11434

# 监控配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 日志配置
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d
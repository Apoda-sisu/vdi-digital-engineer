# VDI 数字工程师 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ===========================
# AI 视觉模型 API（用于验证码识别）
# ===========================
CAPTCHA_VISION_PROVIDER=openai
CAPTCHA_VISION_API_KEY=your-api-key-here
CAPTCHA_VISION_BASE_URL=https://api.openai.com/v1
CAPTCHA_VISION_MODEL=mimo-v2.5

# ===========================
# PilotDeck 工作空间根目录
# ===========================
VDI_WORKSPACE_ROOT=/workspace/workspaces

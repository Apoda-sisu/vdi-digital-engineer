# Docker 构建优化文件
# 排除不需要的文件和目录

# 排除 Git 相关文件
.git
.gitignore
.gitattributes

# 排除 IDE 和编辑器配置
.vscode
.idea
*.swp
*.swo
*~

# 排除测试和文档
*.test.js
*.spec.js
tests/
docs/
*.md

# 排除日志和缓存
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 排除依赖目录（因为会在容器中安装）
node_modules/
.pnp
.pnp.js

# 排除环境配置文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 排除 Docker 相关文件
Dockerfile*
docker-compose*.yml
.dockerignore

# 排除构建产物
dist/
build/
out/

# 排除临时文件
tmp/
temp/
*.tmp
*.temp

# 排除操作系统文件
.DS_Store
Thumbs.db

# 排除工作空间目录（因为会挂载卷）
workspaces/

# 排除数据库文件
*.db
*.sqlite
*.sqlite3

# 排除日志文件
*.log
logs/

# 排除 Python 相关文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# 排除 FreeCAD 输出文件
*.FCStd
*.FCBak

# 门禁：禁止根目录 skills/ 与 vdi-*-workspace/（canonical 在 workspaces/）
/skills/
/vdi-*-workspace/

docs/
backup*/
workspaces/

# ===========================
# 依赖与构建产物
# ===========================
node_modules/
venv/
__pycache__/
*.pyc
*.pyo
dist/
build/
*.egg-info/

# ===========================
# 环境变量与密钥（敏感信息）
# ===========================
.env
.env.*
*.env
!.env.example

# ===========================
# 数据库与索引（运行时生成）
# ===========================
*.db
*.sqlite
*.sqlite3
milvus_lite.db
pilotdeck-vdi/data/milvus_lite.db
pilotdeck-vdi/data/indices/

# ===========================
# 日志与临时文件
# ===========================
*.log
*.tmp
*.temp
/tmp/
.DS_Store
Thumbs.db

# ===========================
# 编辑器与IDE
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~

# ===========================
# 采集器（含敏感配置和RPA脚本）
# ===========================
pilotdeck-vdi/collector/

# ===========================
# PilotDeck 运行时数据
# ===========================
**/.pilotdeck/projects/*/events/
**/.pilotdeck/projects/*/artifacts/
**/.pilotdeck/projects/*/plans/

# ===========================
# 知识库大文件（超过 50MB 的 PDF 等）
# ===========================
*.pdf
*.PDF

# ===========================
# Docker 挂载卷（运行时生成）
# ===========================
pilotdeck-vdi/data/evaluation-report.json
pilotdeck-vdi/tests/health-report-*.json
pilotdeck-vdi/tests/integration-test-report.json
pilotdeck-vdi/tests/module-matching-report.json
